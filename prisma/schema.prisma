// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Calculation {
  id               String   @id @default(cuid())
  monthlyBill      Float
  location         String?
  systemSizeKW     Float
  panelCount       Int
  totalInvestment  Float
  monthlySavings   Float
  paybackYears     Float
  co2Reduction     Float
  
  // New Mode-Aware Fields
  calculationMode  String   @default("SIMPLE")
  unitPrice        Float?
  panelWattage     Float?
  efficiency       Float?
  costPerKW        Float?
  
  // Engineering Physics & Usage Dynamics
  orientation      String?  @default("South") // South, EastWest, North
  tilt             Float?   @default(15)
  daytimeUsageRatio Float?  @default(0.6)
  peakSunHours     Float?   @default(4.2)

  // Identity Segregation (No-login)
  userId           String   @default("anonymous")

  createdAt        DateTime @default(now())

  // Simulation & Optimization State
  isOptimized      Boolean  @default(false)
  sellBackEnabled  Boolean  @default(false)

  @@index([userId])
}
